# Vercel Environment Variables Example

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://peyzajbul.com

# Admin Security (Örn: /yonetim-gizli-portal)
NEXT_PUBLIC_ADMIN_SECRET_PATH=/admin-dash

# Email (Resend) - If used in the frontend directly or via API routes
# RESEND_API_KEY=your_resend_api_key
